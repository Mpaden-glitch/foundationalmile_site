---
/**
 * Foundational Mile LLC — Homepage
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Foundational Mile LLC helps ministries, nonprofits, and mission-driven organizations realign their technology, processes, and decisions with their mission and the people they exist to serve." />
    <meta name="theme-color" content="#0f172a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <title>Foundational Mile LLC — Mission-Aligned Technology Consulting</title>
    <link rel="canonical" href="https://foundationalmile.com/" />
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">

    <!-- Geometric background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="text-lg font-semibold text-slate-100 hover:text-accent transition-colors">Foundational Mile LLC</a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="/services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-slate-100 transition-colors">Our Work</a>
          <a href="/website-strategy-catalog" class="text-slate-400 hover:text-slate-100 transition-colors">Website Strategy</a>
          <a href="/contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>

      <!-- ─── HERO ────────────────────────────────────────────── -->
      <section class="min-h-[90vh] flex flex-col justify-center px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-6">For ministries, nonprofits, and mission-driven organizations</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-50 leading-tight mb-8">
            Technology changes.<br class="hidden sm:block" /> Your mission doesn't.<br class="hidden sm:block" /> That's our starting point.
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
            We help established ministries, nonprofits, and mission-driven organizations realign their technology, decisions, and systems with the mission and the people they exist to serve.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/contact"
              class="inline-block px-8 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors"
            >
              Book a Clarity Call
            </a>
            <a
              href="#how-we-work"
              class="inline-block px-8 py-4 border border-slate-700 text-slate-300 font-medium rounded-lg hover:border-slate-500 hover:text-slate-100 transition-colors"
            >
              See How We Work
            </a>
          </div>
        </div>
      </section>

      <!-- ─── WHO THIS IS FOR ─────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <div class="max-w-2xl mb-14">
            <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Who This Is For</p>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-50 leading-snug">
              This might sound familiar
            </h2>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                Your website or digital presence exists, but you are not confident it is actually reaching or serving the people it's meant to.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                You have added tools and platforms over time, and now things feel fragmented, hard to maintain, or disconnected from how your team actually works.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                Technology decisions get made reactively — driven by urgency or outside pressure, not by a clear sense of where you are trying to go.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                You have invested in a build, a platform, or a redesign that did not deliver what you expected — and you are not entirely sure why.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                Something feels off between what your organization is doing and who you are actually serving — but it is hard to name precisely or know where to start.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-slate-300 text-sm leading-relaxed">
                You want your technology to serve your community and your mission. Right now, it mostly just takes effort to keep running.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── WHAT WE DO ──────────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_1.6fr] gap-12 md:gap-20 items-start">
          <div>
            <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Our Approach</p>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-50 leading-snug">
              Clarity before everything else
            </h2>
          </div>
          <div class="space-y-6 text-slate-300 leading-relaxed">
            <p>
              Most organizations that come to us think they have a technology problem. By the time we have finished listening, the real issue is usually clearer — and it is almost never just the tools. It is the gap between what the organization is trying to do and how its systems, processes, and decisions actually support that.
            </p>
            <p>
              We close that gap before recommending anything. That means asking hard questions before suggesting solutions, reviewing what already exists before proposing something new, and making sure every decision is grounded in your mission and the people you exist to serve.
            </p>
            <div class="space-y-3 pt-2">
              <div class="flex gap-3 items-start">
                <span class="text-accent mt-1 flex-shrink-0">–</span>
                <p class="text-slate-400 text-sm leading-relaxed">We help you understand your mission, your audience, and your current state before proposing a direction.</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="text-accent mt-1 flex-shrink-0">–</span>
                <p class="text-slate-400 text-sm leading-relaxed">We identify where your technology, processes, or decisions are working against you rather than for you.</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="text-accent mt-1 flex-shrink-0">–</span>
                <p class="text-slate-400 text-sm leading-relaxed">We define a practical path forward — and support implementation where it genuinely helps.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SERVICE CARDS ───────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-wrap items-end justify-between gap-4 mb-14">
            <div>
              <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">How We Engage</p>
              <h2 class="text-3xl md:text-4xl font-bold text-slate-50">What this looks like in practice</h2>
            </div>
            <a href="/services" class="inline-flex items-center gap-2 text-accent hover:text-accent-light transition-colors font-medium text-sm mb-1">
              Full service detail
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <div class="grid sm:grid-cols-3 gap-6">
            <a href="/services#strategic" class="group rounded-xl border border-slate-800 bg-slate-900/50 p-7 hover:border-slate-600 transition-colors block">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <span class="text-accent font-mono text-lg">01</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-3 group-hover:text-slate-50 transition-colors">Strategic Clarity & Decision Mapping</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Before any tool gets evaluated or any system gets changed, we help you get clear on what you are trying to accomplish, who you are serving, and what decisions will actually move you forward.
              </p>
            </a>
            <a href="/services#digital" class="group rounded-xl border border-slate-800 bg-slate-900/50 p-7 hover:border-slate-600 transition-colors block">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <span class="text-accent font-mono text-lg">02</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-3 group-hover:text-slate-50 transition-colors">Digital Experience & Technology Alignment</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Your website, tools, and systems should serve your audience and your team — not just exist. We make sure what gets built or changed is the right thing for the right people.
              </p>
            </a>
            <a href="/services#measurement" class="group rounded-xl border border-slate-800 bg-slate-900/50 p-7 hover:border-slate-600 transition-colors block">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <span class="text-accent font-mono text-lg">03</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-3 group-hover:text-slate-50 transition-colors">Measurement, AI & Operational Enablement</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Better visibility into what is working, smarter use of the tools you already have, and practical use of AI where it genuinely helps — without hype or unnecessary overhead.
              </p>
            </a>
          </div>
        </div>
      </section>

      <!-- ─── HOW WE WORK ─────────────────────────────────────── -->
      <section id="how-we-work" class="scroll-mt-20 px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <div class="max-w-2xl mb-14">
            <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">The Process</p>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-50 leading-snug">Simple by design</h2>
            <p class="text-slate-400 mt-4 leading-relaxed">
              Every engagement is different. The sequence is not.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-accent font-mono text-sm mb-4">01</p>
              <h3 class="text-base font-semibold text-slate-100 mb-2">Listen first</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                We start by understanding your mission, your audience, and where things feel off. We ask questions before drawing conclusions.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-accent font-mono text-sm mb-4">02</p>
              <h3 class="text-base font-semibold text-slate-100 mb-2">Map the gaps</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                We identify where your current tools, processes, or decisions are misaligned with what you are actually trying to accomplish.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-accent font-mono text-sm mb-4">03</p>
              <h3 class="text-base font-semibold text-slate-100 mb-2">Define a clear path</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                We give you a practical, prioritized direction. Not a wish list. Not a long scope document. A clear sense of what to do next and why.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <p class="text-accent font-mono text-sm mb-4">04</p>
              <h3 class="text-base font-semibold text-slate-100 mb-2">Support what comes after</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                If implementation is needed, we help. If not, we make sure you are equipped to move forward without depending on us to do it.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── ABOUT ────────────────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_1.6fr] gap-12 md:gap-20 items-start">
          <div>
            <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">The Practice</p>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-50 leading-snug">
              Why this exists
            </h2>
            <a href="/about" class="inline-flex items-center gap-2 text-accent hover:text-accent-light transition-colors font-medium text-sm mt-6">
              Read the full story
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
          <div class="space-y-5 text-slate-300 leading-relaxed">
            <p>
              I spent years working at the intersection of technology, product, and operations — leading reliability engineering, driving product discovery, building internal platforms, and working across teams to understand what they were actually trying to accomplish. What I kept seeing, across organizations of every size, was the same pattern: enormous effort spent on the wrong things. Not from lack of skill or intention, but because nobody had stopped to ask whether the thing being built was the right thing.
            </p>
            <p>
              That question — is this the right thing? — turned out to be the most valuable one I could ask. It felt like it slowed things down. In practice, it saved months of misdirected effort and produced systems that people actually used. The organizations that asked it first moved faster in the long run and built things that held up.
            </p>
            <p>
              Foundational Mile exists to ask that question earlier and more deliberately — especially for the organizations doing the most important work. Ministries, nonprofits, and mission-driven teams who cannot afford to build the wrong thing or maintain tools that drift from their purpose.
            </p>
            <p class="text-slate-400">
              The best technical partner is not the one who builds fastest. It is the one who helps you understand what you actually need first.
            </p>
          </div>
        </div>
      </section>

      <!-- ─── CREDIBILITY ─────────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-14">Experience</p>
          <div class="grid sm:grid-cols-2 gap-x-16 gap-y-8">
            <div class="flex gap-4 items-start">
              <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">–</span>
              <p class="text-slate-400 text-sm leading-relaxed">Led technology initiatives across engineering, product, and operations — from early discovery through delivery and adoption.</p>
            </div>
            <div class="flex gap-4 items-start">
              <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">–</span>
              <p class="text-slate-400 text-sm leading-relaxed">Built internal platforms and tools that had to work for real users under real conditions — not just pass a demo.</p>
            </div>
            <div class="flex gap-4 items-start">
              <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">–</span>
              <p class="text-slate-400 text-sm leading-relaxed">Drove adoption by centering on what users and stakeholders actually needed, not what was technically possible to deliver.</p>
            </div>
            <div class="flex gap-4 items-start">
              <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">–</span>
              <p class="text-slate-400 text-sm leading-relaxed">Translated between technical teams and non-technical leaders to build shared understanding and reduce wasted effort on both sides.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── FINAL CTA ────────────────────────────────────────── -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-6">Get in touch</p>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-5 leading-snug">
            Most organizations know something is off. They don't always know what.
          </h2>
          <p class="text-slate-400 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
            That is exactly where we start. A clarity call is a focused conversation about your situation — no sales pitch, no agenda, just honest thinking about what you actually need.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/contact"
              class="inline-block px-8 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors"
            >
              Book a Clarity Call
            </a>
            <a href="/about" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-100 transition-colors font-medium text-sm">
              Read about the practice
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </section>

    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>© {new Date().getFullYear()} Foundational Mile LLC</span>
        <div class="flex items-center gap-6">
          <a href="/services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/contact" class="text-slate-400 hover:text-slate-100 transition-colors">Contact</a>
        </div>
      </div>
    </footer>

  </body>
</html>
