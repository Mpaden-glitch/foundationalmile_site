---
/**
 * Foundational Mile LLC — Single-page static site
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Foundational Mile LLC helps small businesses, nonprofits, and ministries understand what they need to build and who they're building it for — before wasting time and money going in the wrong direction. Technical strategy, AI-augmented workflows, and observability consulting." />
    <meta name="theme-color" content="#0f172a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <title>Foundational Mile LLC — Technical Strategy & Discovery for Small Business & Nonprofits</title>
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">
    <!-- Geometric hero background (CSS-only) -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="#" class="text-lg font-semibold text-slate-100 hover:text-accent transition-colors">Foundational Mile LLC</a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="#services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="#about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-slate-100 transition-colors">Our Work</a>
          <a href="#contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <!-- Hero -->
      <section id="hero" class="min-h-[85vh] flex flex-col justify-center px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Technical Consulting</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-50 leading-tight mb-6">
            Know what you need — and who you're building for — before you build.
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">
            Foundational Mile helps small businesses, nonprofits, and ministries get clarity on technical strategy, so you stop wasting time and money going in the wrong direction.
          </p>
          <a href="#contact" class="inline-block px-8 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors">
            Start the conversation
          </a>
        </div>
      </section>

      <!-- Services -->
      <section id="services" class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4">Services</h2>
          <p class="text-slate-400 text-lg max-w-2xl mb-14">
            From discovery to delivery — we help you choose the right direction and build the right thing.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-mono text-lg">01</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Technical Strategy & Discovery</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Clarify goals, constraints, and audiences before a single line of code. Align stakeholders and define what “done” looks like.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-mono text-lg">02</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-2">AI Augmented Workflows</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Integrate AI where it actually helps without hype. Practical automation and tooling that fits how you work.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-mono text-lg">03</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Observability & Reliability</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Move from reactive firefighting to proactive confidence. Monitoring, incident response, and reliability practices that scale with you.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-mono text-lg">04</span>
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Digital Presence for Nonprofits & Ministries</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Websites, donor tools, and outreach that reflect your mission. Built for sustainability and clarity, not lock-in.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4">About</h2>
          <div class="prose prose-invert prose-slate max-w-none text-slate-300 leading-relaxed space-y-4">
            <p>
              Foundational Mile is built on years of work at the intersection of <strong class="text-slate-200">site reliability engineering</strong> and <strong class="text-slate-200">product thinking</strong> — founding SRE functions from scratch, shipping internal platforms, leading discovery-to-delivery product cycles, and helping engineering organizations move from reactive chaos to proactive clarity.
            </p>
            <p>
              That work spanned building teams that didn’t exist yet, shipping tools that real people depended on, and sitting across from stakeholders to understand what they actually needed before writing a single line of requirements. The through line was always the same: the biggest wins come from getting the foundations right before scaling anything on top of them.
            </p>
            <p>
              That experience taught a simple lesson. The organizations that move fastest aren’t the ones with the most technology — they’re the ones who know who they’re serving, what problem they’re actually solving, and what they can confidently skip. Getting to that clarity is harder than it sounds, and it’s exactly where we come in.
            </p>
            <p>
              We work with organizations that have real missions and limited bandwidth. Small businesses, nonprofits, ministries, early-stage teams. The goal is never to sell you more technology. It’s to help you choose the right technology, use it well, and build something your team can own and stand on long after we’re gone.
            </p>
            <p>
              Technical, professional, and human.
            </p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4">Contact</h2>
          <p class="text-slate-400 mb-10">
            Tell us a bit about your organization and what you’re trying to achieve. We’ll get back to you.
          </p>
          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
          >
            <input type="hidden" name="access_key" value="554072d5-a345-473f-904d-04ad815074b7" />
            <input type="hidden" name="subject" value="New Contact Form Submission — Foundational Mile" />
            <input type="hidden" name="from_name" value="Foundational Mile Website" />
            <input type="hidden" name="redirect" value="false" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
            <div>
              <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent resize-y"
                placeholder="What are you trying to achieve? What’s getting in the way?"
              />
            </div>
            <div class="cf-turnstile" data-sitekey="0x4AAAAAACrZpj7N7dorzKW0" data-theme="dark"></div>
            <button
              type="submit"
              id="submit-btn"
              class="w-full px-6 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send message
            </button>
          </form>
          <div id="form-result" class="hidden mt-4 p-4 rounded-lg text-sm"></div>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>© {new Date().getFullYear()} Foundational Mile LLC</span>
        <a href="#hero" class="text-slate-400 hover:text-slate-100 transition-colors">Back to top</a>
      </div>
    </footer>
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const result = document.getElementById('form-result') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending…';
      result.className = 'hidden';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await response.json();

        if (data.success) {
          result.className = 'mt-4 p-4 rounded-lg text-sm bg-green-900/50 border border-green-700 text-green-300';
          result.textContent = "Message sent. We'll be in touch soon.";
          form.reset();
          if (window.turnstile) window.turnstile.reset();
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch {
        result.className = 'mt-4 p-4 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
        result.textContent = 'Something went wrong. Please try again or email us directly.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send message';
      }
    });
  </script>
  </body>
</html>
