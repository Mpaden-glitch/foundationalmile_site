---
/**
 * Foundational Mile LLC — Services
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Foundational Mile LLC services: Strategic Clarity & Decision Mapping, Digital Experience & Technology Alignment, and Measurement, AI & Operational Enablement. Mission-aligned technology consulting for ministries, nonprofits, and purpose-driven organizations." />
    <meta name="theme-color" content="#0f172a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <title>Services — Foundational Mile LLC</title>
    <link rel="canonical" href="https://foundationalmile.com/services" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Services — Foundational Mile LLC" />
    <meta property="og:description" content="Foundational Mile LLC services: Strategic Clarity & Decision Mapping, Digital Experience & Technology Alignment, and Measurement, AI & Operational Enablement. Mission-aligned technology consulting for ministries, nonprofits, and purpose-driven organizations." />
    <meta property="og:url" content="https://foundationalmile.com/services" />
    <meta property="og:type" content="website" />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Foundational Mile LLC",
        "url": "https://foundationalmile.com"
      }
    </script>
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">

    <!-- Geometric background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="text-lg font-semibold text-slate-100 hover:text-accent transition-colors">Foundational Mile LLC</a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="/services" class="text-slate-100 font-medium transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-slate-100 transition-colors">Our Work</a>
          <a href="/website-strategy-catalog" class="text-slate-400 hover:text-slate-100 transition-colors">Website Strategy</a>
          <a href="/contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>

      <!-- Page Header -->
      <section class="min-h-[50vh] flex flex-col justify-center px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Services</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-50 leading-tight mb-6">
            What we do, and how we do it
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
            Every engagement begins the same way: understanding what is actually needed before deciding what to build, buy, or change. Technology is a tool. Mission is the starting point.
          </p>
        </div>
      </section>

      <!-- Service Detail Sections -->
      <section class="px-6 pb-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto pt-20 space-y-28">

          <!-- 01 Strategic Clarity -->
          <div id="strategic" class="scroll-mt-24 grid md:grid-cols-[1fr_2fr] gap-10 md:gap-20 items-start">
            <div class="md:sticky md:top-28">
              <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">01</p>
              <h2 class="text-2xl font-bold text-slate-50 mb-6">Strategic Clarity & Decision Mapping</h2>
              <ul class="space-y-2.5 text-sm text-slate-500">
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Mission and goals alignment</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Stakeholder and audience mapping</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Current tools and process review</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Gap and risk identification</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Prioritized decision roadmap</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Clear build, buy, or skip guidance</li>
              </ul>
            </div>
            <div class="text-slate-400 leading-relaxed space-y-5">
              <p>
                Most technology problems are alignment problems. Organizations end up over-built, under-organized, or stuck — not because they chose bad tools, but because nobody stopped to ask the right questions before moving forward. They built something that worked technically and missed the mission entirely.
              </p>
              <p>
                This engagement changes that sequence. We work through what your organization is actually trying to accomplish, who you are serving, and what your current tools and processes genuinely do — then map the gap between where you are and where you need to be. The outcome is a grounded, shared understanding of priorities, so your next move is intentional rather than reactive.
              </p>
              <p>
                This is the right starting point for any significant technology or operational decision. It frequently surfaces things that save substantial time and budget before a single line of code is written — and it gives your leadership the clarity they need to make better decisions long after the engagement ends.
              </p>
              <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 mt-8">
                <p class="text-sm font-medium text-slate-300 mb-2">A good fit if you are:</p>
                <ul class="space-y-1.5 text-sm text-slate-500">
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Considering a new platform, tool, or system and not sure where to start</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Dealing with fragmented processes, unclear ownership, or tools your team has outgrown</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>About to invest in a build and want to make sure it is the right build</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>A leader who needs to make a significant technology decision and wants honest, structured input before committing</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="border-t border-slate-800/50"></div>

          <!-- 02 Digital Experience -->
          <div id="digital" class="scroll-mt-24 grid md:grid-cols-[1fr_2fr] gap-10 md:gap-20 items-start">
            <div class="md:sticky md:top-28">
              <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">02</p>
              <h2 class="text-2xl font-bold text-slate-50 mb-6">Digital Experience & Technology Alignment</h2>
              <ul class="space-y-2.5 text-sm text-slate-500">
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Audience-first website strategy</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Digital tools and platform review</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Build or configuration implementation</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Forms, scheduling, and integrations</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Launch readiness and handoff</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Team training and documentation</li>
              </ul>
            </div>
            <div class="text-slate-400 leading-relaxed space-y-5">
              <p>
                A website is only useful if it serves the right people and actually gets maintained by the team that owns it. The same is true of any digital tool or system. Too many organizations end up with a presence that was built for the wrong audience, organized around the wrong priorities, or handed off without any real plan for keeping it useful.
              </p>
              <p>
                This is not just about websites. It is about your entire digital surface — the tools your team uses, how they connect, and whether the experience you are creating for the people you serve actually reflects your mission. We start with strategy: who this is for, what they need to understand or feel, and what action you want them to take. From there we structure the experience, build or configure what is needed, and wire in the supporting pieces that reduce friction for your audience and burden for your team.
              </p>
              <p>
                The goal is a handoff, not a dependency. When we are done, your team understands how things work, how to make updates, and how to keep it useful. You should not need to call us to change a page headline after launch.
              </p>
              <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 mt-8">
                <p class="text-sm font-medium text-slate-300 mb-2">We work most often with:</p>
                <ul class="space-y-1.5 text-sm text-slate-500">
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Ministries and nonprofits that need a clean, maintainable online presence that reflects who they are</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Schools and community organizations building digital experiences for a specific, known audience</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Organizations rebuilding after a previous project did not deliver what was actually needed</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Teams that have the right tools but are not getting value from them because setup and strategy were skipped</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="border-t border-slate-800/50"></div>

          <!-- 03 Measurement, AI & Operational Enablement -->
          <div id="measurement" class="scroll-mt-24 grid md:grid-cols-[1fr_2fr] gap-10 md:gap-20 items-start">
            <div class="md:sticky md:top-28">
              <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">03</p>
              <h2 class="text-2xl font-bold text-slate-50 mb-6">Measurement, AI & Operational Enablement</h2>
              <ul class="space-y-2.5 text-sm text-slate-500">
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Impact and outcomes measurement</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Reporting and visibility setup</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Honest AI fit assessment</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Workflow review and automation</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Operational burden reduction</li>
                <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">–</span>Team adoption and capability building</li>
              </ul>
            </div>
            <div class="text-slate-400 leading-relaxed space-y-5">
              <p>
                You cannot align technology with your mission if you cannot see what is actually happening. Many organizations are working hard but flying blind — no consistent way to measure what is working, no visibility into where time is being lost, and no structured way to decide whether a new tool would help or just add more complexity.
              </p>
              <p>
                This engagement builds the infrastructure for informed decision-making. That means establishing meaningful metrics tied to your actual goals, building lightweight reporting that your leadership can act on, and identifying where automation or AI would genuinely reduce the operational burden on your team — not just add novelty. AI is useful in specific, well-defined places. The hard part is identifying those places honestly before spending time and money finding out the hard way.
              </p>
              <p>
                The outcome is a team that can see what is happening, understand what it means, and use the right tools — including AI where it actually helps — to spend more time on mission and less time on overhead. That is a practical, durable improvement, not a platform subscription.
              </p>
              <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 mt-8">
                <p class="text-sm font-medium text-slate-300 mb-2">Common starting points:</p>
                <ul class="space-y-1.5 text-sm text-slate-500">
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Organizations that cannot clearly articulate what "working" looks like — and know that is a problem</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Teams spending significant time on repetitive tasks that could be automated or assisted</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Leaders who want an honest answer to "where would AI actually help us?" before committing</li>
                  <li class="flex gap-2.5 items-start"><span class="text-accent mt-0.5 flex-shrink-0">·</span>Nonprofits and ministries that need to report on impact but do not have a consistent way to gather or present it</li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- CTA -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-5">Not sure which fits your situation?</h2>
          <p class="text-slate-400 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
            Most engagements start with a conversation, not a service menu. Tell us what is going on and we will tell you honestly what kind of help makes sense.
          </p>
          <a
            href="/contact"
            class="inline-block px-8 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors"
          >
            Book a Clarity Call
          </a>
        </div>
      </section>

    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>© {new Date().getFullYear()} Foundational Mile LLC</span>
        <div class="flex items-center gap-6">
          <a href="/services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-slate-100 transition-colors">Our Work</a>
          <a href="/contact" class="text-slate-400 hover:text-slate-100 transition-colors">Contact</a>
        </div>
      </div>
    </footer>

  </body>
</html>
