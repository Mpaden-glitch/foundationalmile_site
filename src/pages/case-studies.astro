---
/**
 * Foundational Mile LLC — Our Work
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Our Work — Foundational Mile LLC. Case studies and engagement snapshots from mission-driven organizations we have supported." />
    <meta name="theme-color" content="#041638" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />
    <link rel="preload" as="image" href="/brand/logo-inverse.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <title>Our Work — Foundational Mile LLC</title>
    <link rel="canonical" href="https://foundationalmile.com/case-studies" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Our Work — Foundational Mile LLC" />
    <meta property="og:description" content="Our Work — Foundational Mile LLC. Case studies and engagement snapshots from mission-driven organizations we have supported." />
    <meta property="og:url" content="https://foundationalmile.com/case-studies" />
    <meta property="og:type" content="website" />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Foundational Mile LLC",
        "url": "https://foundationalmile.com"
      }
    </script>
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-brand-navy text-slate-100 font-sans antialiased">
    <!-- Geometric background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-brand-navy/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="inline-flex items-center gap-3 rounded-md focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-brand-navy" aria-label="Foundational Mile LLC home"><img src="/brand/logo-inverse.png" alt="Foundational Mile LLC logo" class="h-8 w-auto sm:h-9" loading="eager" decoding="sync" width="146" height="141" /><span class="text-base sm:text-lg font-semibold text-slate-100">Foundational Mile LLC</span></a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="/services" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-100 font-medium transition-colors">Our Work</a>
          <a href="/website-strategy-catalog" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Website Strategy</a>
          <a href="/contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="min-h-[60vh] flex flex-col justify-center px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Our Work</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-50 leading-tight mb-6">
            Real work. Real results.
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl">
            A look at the kinds of engagement work we support and the outcomes we help organizations pursue.
          </p>
        </div>
      </section>

      <section class="px-6 pb-28 border-t border-slate-800/50">
        <div class="max-w-4xl mx-auto pt-20">
          <article class="rounded-2xl border border-slate-700/70 bg-slate-900/70 p-8 md:p-10 mb-8">
            <p class="text-accent font-mono text-xs uppercase tracking-[0.2em] mb-4">Featured Engagement</p>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-8">
              <div>
                <h2 class="text-2xl md:text-3xl font-bold text-slate-100 mb-2">Limitless Christian Academy</h2>
                <p class="text-slate-400 max-w-2xl">
                  Website strategy, custom build, and platform integration support for a mission-driven school.
                </p>
              </div>
              <div class="w-full sm:w-56 p-1">
                <img
                  src="/clients/limitless-christian-academy/logo-white.png"
                  alt="Limitless Christian Academy logo"
                  class="w-full h-auto object-contain"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>

            <blockquote class="border-l-2 border-accent/70 pl-5 md:pl-6">
              <p class="text-slate-200 leading-relaxed md:text-lg">
                "Foundational Mile delivered exactly what Limitless Christian Academy needed. A fully customized website built around our specific vision with no limitations. Matthew listened carefully, responded quickly, and served as a thoughtful sounding board on everything from design and site flow to integrating multiple platforms seamlessly. He was not just a developer but a true partner in building something we are proud to represent our school."
              </p>
              <footer class="mt-4 text-sm text-slate-400">
                Head of School, Limitless Christian Academy
              </footer>
            </blockquote>

            <div class="mt-8">
              <a
                href="https://limitlesschristianacademy.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-6 py-3 bg-accent text-brand-navy font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-brand-navy transition-colors"
              >
                Visit Limitless Christian Academy
              </a>
            </div>
          </article>

          <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-12 md:p-16 text-center">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-6">
              <span class="text-accent font-mono text-2xl">✦</span>
            </div>
            <h2 class="text-2xl font-bold text-slate-100 mb-4">More case snapshots coming soon.</h2>
            <p class="text-slate-400 text-lg max-w-xl mx-auto mb-8">
              This page is expanding as additional client approvals and project writeups are finalized.
            </p>
            <a
              href="/contact"
              class="inline-block px-8 py-4 bg-accent text-brand-navy font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-brand-navy transition-colors"
            >
              Start the conversation
            </a>
            <p class="mt-6 text-sm text-slate-500">
              Looking for service details first?
              <a href="/services" class="text-slate-300 hover:text-slate-100 transition-colors">View services</a>.
            </p>

          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-3"><span class="inline-flex items-center justify-center rounded-full bg-white/90 p-1 ring-1 ring-slate-300/30"><img src="/brand/logo-primary.png" alt="Foundational Mile LLC logo" class="h-8 w-8" loading="lazy" decoding="async" /></span><span>© {new Date().getFullYear()} Foundational Mile LLC</span></div>
        <a href="/" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Back to home</a>
      </div>
    </footer>
  </body>
</html>
