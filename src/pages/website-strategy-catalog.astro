---
/**
 * Foundational Mile LLC — Website Strategy Catalog
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Different industries require different website strategies. Explore how audience-first thinking helps businesses build websites that actually work — from ministries to contractors to chiropractors." />
    <meta name="theme-color" content="#041638" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />
    <link rel="preload" as="image" href="/brand/logo-inverse.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <title>Website Strategy Catalog — Foundational Mile LLC</title>
    <link rel="canonical" href="https://foundationalmile.com/website-strategy-catalog" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Website Strategy Catalog — Foundational Mile LLC" />
    <meta property="og:description" content="Different industries require different website strategies. Explore how audience-first thinking helps businesses build websites that actually work — from ministries to contractors to chiropractors." />
    <meta property="og:url" content="https://foundationalmile.com/website-strategy-catalog" />
    <meta property="og:type" content="website" />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Foundational Mile LLC",
        "url": "https://foundationalmile.com"
      }
    </script>
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-brand-navy text-slate-100 font-sans antialiased">
    <!-- Geometric background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-brand-navy/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="inline-flex items-center gap-3 rounded-md focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-brand-navy" aria-label="Foundational Mile LLC home"><img src="/brand/logo-inverse.png" alt="Foundational Mile LLC logo" class="h-8 w-auto sm:h-9" loading="eager" decoding="sync" width="146" height="141" /><span class="text-base sm:text-lg font-semibold text-slate-100">Foundational Mile LLC</span></a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="/services" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Our Work</a>
          <a href="/website-strategy-catalog" class="text-slate-100 font-medium transition-colors">Website Strategy</a>
          <a href="/contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>

      <!-- Hero -->
      <section class="min-h-[60vh] flex flex-col justify-center px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto">
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Website Strategy</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-50 leading-tight mb-6">
            Websites Are More Than Just Websites
          </h1>
          <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
            A website is the digital front door to your mission, your audience, and the action you want people to take.
          </p>
        </div>
      </section>

      <!-- Problem Section -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-6">Most businesses build the wrong website</h2>
          <div class="space-y-5 text-slate-300 leading-relaxed text-lg">
            <p>
              Not because they chose bad technology. Not because they skipped a feature. But because they didn't stop to ask the right questions first.
            </p>
            <p>
              Who is this for? What do they need to feel before they'll act? What's getting in the way? What do we actually want them to do?
            </p>
            <p>
              When you skip those questions, you end up with a website that looks fine but doesn't work — one that gets traffic but no calls, has a contact form nobody fills out, and pages that are hard to navigate for the very people you're trying to reach.
            </p>
          </div>
        </div>
      </section>

      <!-- Industry Differences -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4">Every industry has a different audience. Every audience needs something different.</h2>
          <p class="text-slate-400 text-lg max-w-2xl mb-14">
            The strategy that works for a cleaning company won't work for a ministry. The approach that converts for a chiropractor isn't the right approach for a private school.
          </p>

          <div class="grid sm:grid-cols-2 gap-6">
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Ministries</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                A ministry website isn't selling a service — it's extending a welcome. A first-time visitor needs to feel like they belong before they ever walk through the door. That requires warmth, clarity, and removing every barrier between curiosity and connection.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Construction Contractors</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Homeowners hiring a contractor are handing someone a key to their home. Trust is everything. A contractor's website must prove past work, show real results, and make it easy to take the next step — before a competitor does.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Chiropractors</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Many people searching for a chiropractor have never been to one. They're in pain and they're nervous. The right website reduces that anxiety, explains what to expect, and makes booking as simple as possible.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors">
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Cleaning Companies</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Someone booking a cleaning service wants it fast and easy. They want to know the price, trust that the team is reliable, and book without jumping through hoops. Friction kills conversions here more than anywhere else.
              </p>
            </article>
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 hover:border-slate-700 transition-colors sm:col-span-2">
              <h3 class="text-lg font-semibold text-slate-100 mb-2">Private Schools</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Parents choosing a school are making one of the most important decisions of their family's life. A private school website must balance academic credibility, community warmth, and practical information — and make it easy to take the next step.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- Core Idea Block -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto">
          <div class="rounded-2xl border border-amber-500/20 bg-amber-500/5 p-10 md:p-14 text-center">
            <p class="text-2xl md:text-3xl font-bold text-slate-50 leading-snug mb-4">
              "The goal is not just to have a website."
            </p>
            <p class="text-xl text-slate-300 leading-relaxed">
              The goal is to help the right people understand, trust, and take the next step.
            </p>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="px-6 py-20 md:py-28 border-t border-slate-800/50">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-50 mb-4">Explore the Website Strategy Catalog</h2>
          <p class="text-slate-400 text-lg mb-10 max-w-xl mx-auto">
            This catalog shows how different industries require different website strategies based on audience, trust, and goals. Not templates — thinking.
          </p>
          <a
            href="https://mpaden-glitch.github.io/Website-general-examples/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 bg-accent text-brand-navy font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-brand-navy transition-colors"
          >
            View the Catalog
          </a>
        </div>
      </section>

    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-3"><span class="inline-flex items-center justify-center rounded-full bg-white/90 p-1 ring-1 ring-slate-300/30"><img src="/brand/logo-primary.png" alt="Foundational Mile LLC logo" class="h-8 w-8" loading="lazy" decoding="async" /></span><span>© {new Date().getFullYear()} Foundational Mile LLC</span></div>
        <a href="/" class="text-slate-400 font-medium hover:text-slate-100 transition-colors">Back to home</a>
      </div>
    </footer>
  </body>
</html>
