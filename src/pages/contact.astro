---
/**
 * Foundational Mile LLC — Contact
 * Astro + Tailwind CSS. Deploy to Cloudflare Pages.
 */
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Get in touch with Foundational Mile LLC. Tell us what you're working on and we'll help figure out where to start." />
    <meta name="theme-color" content="#0f172a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <title>Contact — Foundational Mile LLC</title>
    <link rel="canonical" href="https://foundationalmile.com/contact" />
    <style is:global>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">

    <!-- Geometric background -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-accent/5 blur-3xl"></div>
      <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-slate-700/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-slate-700/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-slate-600/15 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] border border-accent/10 rounded-full"></div>
      <svg class="absolute top-20 right-20 w-64 h-64 text-slate-800/40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 L50 10 L90 50 L50 90 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M25 50 L50 25 L75 50 L50 75 Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
      <svg class="absolute bottom-32 left-16 w-48 h-48 text-slate-800/30" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.5" />
      </svg>
    </div>

    <header class="border-b border-slate-800/50 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="text-lg font-semibold text-slate-100 hover:text-accent transition-colors">Foundational Mile LLC</a>
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <a href="/services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-slate-100 transition-colors">Our Work</a>
          <a href="/website-strategy-catalog" class="text-slate-400 hover:text-slate-100 transition-colors">Website Strategy</a>
          <a href="/contact" class="text-accent font-medium hover:text-accent-light transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <main>

      <section class="px-6 py-20 md:py-28">
        <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_1.4fr] gap-16 md:gap-24 items-start">

          <!-- Left: Intro + What to expect -->
          <div>
            <p class="text-accent font-mono text-sm uppercase tracking-widest mb-4">Contact</p>
            <h1 class="text-3xl md:text-4xl font-bold text-slate-50 leading-snug mb-6">
              Tell us what you're working on
            </h1>
            <p class="text-slate-400 leading-relaxed mb-10">
              We read every message and respond to all of them. If you are not sure how to describe the problem yet, that is fine — most good conversations start that way.
            </p>

            <div class="space-y-5">
              <p class="text-sm font-medium text-slate-300 uppercase tracking-wider">What happens next</p>
              <div class="space-y-4">
                <div class="flex gap-4 items-start">
                  <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">01</span>
                  <p class="text-sm text-slate-400 leading-relaxed">We read your message and respond within one business day.</p>
                </div>
                <div class="flex gap-4 items-start">
                  <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">02</span>
                  <p class="text-sm text-slate-400 leading-relaxed">If it sounds like a fit, we'll schedule a short call to understand more before proposing anything.</p>
                </div>
                <div class="flex gap-4 items-start">
                  <span class="text-accent font-mono text-sm mt-0.5 flex-shrink-0">03</span>
                  <p class="text-sm text-slate-400 leading-relaxed">That call is free, low-pressure, and focused entirely on understanding your situation — not selling you something.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Form -->
          <div>
            <form
              id="contact-form"
              action="/api/contact"
              method="POST"
              class="space-y-6"
            >

              <div>
                <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
                  placeholder="you@example.com"
                />
              </div>
              <div>
                <label for="org" class="block text-sm font-medium text-slate-300 mb-2">Organization <span class="text-slate-600 font-normal">(optional)</span></label>
                <input
                  type="text"
                  id="org"
                  name="organization"
                  class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-colors"
                  placeholder="Business, nonprofit, ministry, etc."
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-slate-300 mb-2">What are you working on?</label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent resize-y transition-colors"
                  placeholder="Tell us what is going on. What are you trying to accomplish, what is getting in the way, and what kind of help you think you need — even if you are not sure yet."
                />
              </div>
              <div class="cf-turnstile" data-sitekey="0x4AAAAAACrZpj7N7dorzKW0" data-theme="dark"></div>
              <button
                type="submit"
                id="submit-btn"
                class="w-full px-6 py-4 bg-accent text-slate-950 font-semibold rounded-lg hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-950 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Send message
              </button>
            </form>
            <div id="form-result" class="hidden mt-4 p-4 rounded-lg text-sm"></div>
          </div>

        </div>
      </section>

    </main>

    <footer class="border-t border-slate-800/50 px-6 py-8">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>© {new Date().getFullYear()} Foundational Mile LLC</span>
        <div class="flex items-center gap-6">
          <a href="/services" class="text-slate-400 hover:text-slate-100 transition-colors">Services</a>
          <a href="/about" class="text-slate-400 hover:text-slate-100 transition-colors">About</a>
          <a href="/contact" class="text-slate-400 hover:text-slate-100 transition-colors">Contact</a>
        </div>
      </div>
    </footer>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const result = document.getElementById('form-result') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending…';
      result.className = 'hidden';

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await response.json();

        if (data.success) {
          result.className = 'mt-4 p-4 rounded-lg text-sm bg-green-900/50 border border-green-700 text-green-300';
          result.textContent = data.message;
          form.reset();
          if (window.turnstile) window.turnstile.reset();
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        result.className = 'mt-4 p-4 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
        result.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send message';
      }
    });
  </script>
  </body>
</html>
