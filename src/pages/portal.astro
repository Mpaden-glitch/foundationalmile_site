---
import PortalLayout from '../layouts/PortalLayout.astro';
import { requirePortalAuth } from '../lib/portal/auth';
import { getPortalRuntime } from '../lib/portal/runtime';

export const prerender = false;

function toPortalErrorResponse(error: unknown): Response {
  const status =
    typeof error === 'object' &&
    error !== null &&
    'status' in error &&
    typeof (error as { status?: unknown }).status === 'number'
      ? (error as { status: number }).status
      : 500;

  return new Response(status === 401 ? 'Unauthorized.' : status === 403 ? 'Forbidden.' : 'Internal server error.', { status });
}

let auth!: Awaited<ReturnType<typeof requirePortalAuth>>;
let authError: unknown = null;

try {
  const { env, db } = getPortalRuntime(Astro.locals as App.Locals);
  auth = await requirePortalAuth(Astro.request, env, db, { auditBootstrap: true });
} catch (error) {
  authError = error;
}

if (authError) {
  return toPortalErrorResponse(authError);
}

if (auth.authorizedSites.length === 1) {
  return Astro.redirect(`/portal/sites/${auth.authorizedSites[0].id}`);
}

const sites = auth.authorizedSites;
---
<PortalLayout title="Portal Home" userEmail={auth.user.email}>
  <section class="rounded-xl border border-slate-800 bg-slate-900/60 p-8">
    <h1 class="text-2xl md:text-3xl font-semibold text-slate-100">Portal Home</h1>
    <p class="text-slate-400 mt-2">Access your authorized sites and submit support requests.</p>
  </section>

  {sites.length === 0 ? (
    <section class="mt-8 rounded-xl border border-slate-800 bg-slate-900/40 p-8">
      <h2 class="text-lg font-semibold text-slate-100">No authorized sites</h2>
      <p class="text-slate-400 mt-2">Your account is authenticated but not currently mapped to any site.</p>
    </section>
  ) : (
    <section class="mt-8">
      <h2 class="text-lg font-semibold text-slate-100 mb-4">Your Sites</h2>
      <ul class="grid gap-4">
        {sites.map((site) => (
          <li class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
            <a href={`/portal/sites/${site.id}`} class="text-lg font-semibold text-accent hover:text-accent-light transition-colors">
              {site.displayName}
            </a>
            <p class="text-slate-400 text-sm mt-1">{site.domain}</p>
            <p class="text-slate-400 text-sm mt-1">{site.clientName} · role: {site.role}</p>
          </li>
        ))}
      </ul>
    </section>
  )}
</PortalLayout>
