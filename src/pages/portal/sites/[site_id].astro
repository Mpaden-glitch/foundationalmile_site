---
import PortalLayout from '../../../layouts/PortalLayout.astro';
import { assertSiteAccess, requirePortalAuth } from '../../../lib/portal/auth';
import { getPortalRuntime } from '../../../lib/portal/runtime';
import { requireSiteId } from '../../../lib/portal/validation';

export const prerender = false;

function toPortalErrorResponse(error: unknown): Response {
  const status =
    typeof error === 'object' &&
    error !== null &&
    'status' in error &&
    typeof (error as { status?: unknown }).status === 'number'
      ? (error as { status: number }).status
      : 500;

  return new Response(status === 401 ? 'Unauthorized.' : status === 403 ? 'Forbidden.' : 'Internal server error.', { status });
}

let auth!: Awaited<ReturnType<typeof requirePortalAuth>>;
let siteId = '';
let role: 'viewer' | 'requester' = 'viewer';
let authError: unknown = null;

try {
  const { env, db } = getPortalRuntime(Astro.locals as App.Locals);
  auth = await requirePortalAuth(Astro.request, env, db);
  siteId = requireSiteId(Astro.params.site_id);
  role = assertSiteAccess(siteId, auth);
} catch (error) {
  authError = error;
}

if (authError) {
  return toPortalErrorResponse(authError);
}

const site = auth.authorizedSites.find((candidate) => candidate.id === siteId);
if (!site) {
  return new Response('Forbidden.', { status: 403 });
}
---
<PortalLayout title={site.displayName} userEmail={auth.user.email}>
  <section class="rounded-xl border border-slate-800 bg-slate-900/60 p-8">
    <p class="text-sm font-mono text-slate-400 uppercase tracking-wider">Site</p>
    <h1 class="text-2xl md:text-3xl font-semibold text-slate-100 mt-2">{site.displayName}</h1>
    <p class="text-slate-400 mt-2">{site.domain}</p>
    <p class="text-slate-400 mt-1">Client: {site.clientName}</p>
    <p class="text-slate-400 mt-1">Your role: {role}</p>
  </section>

  <section class="mt-8 rounded-xl border border-slate-800 bg-slate-900/40 p-8">
    <h2 class="text-lg font-semibold text-slate-100">Requests</h2>
    <p class="text-slate-400 mt-2">View and submit requests for this site.</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href={`/portal/sites/${site.id}/requests`}
        class="inline-flex items-center px-4 py-2 rounded-md bg-accent text-brand-navy font-medium hover:bg-accent-light transition-colors"
      >
        View Requests
      </a>
      {role === 'requester' ? (
        <a
          href={`/portal/sites/${site.id}/requests/new`}
          class="inline-flex items-center px-4 py-2 rounded-md border border-slate-600 text-slate-200 hover:border-slate-400 hover:text-white transition-colors"
        >
          New Request
        </a>
      ) : null}
    </div>
  </section>
</PortalLayout>
