# Existing contact form runtime vars
TURNSTILE_SECRET_KEY=replace-me
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL="Foundational Mile <contact@yourdomain.com>"
CONTACT_TO_EMAIL=you@example.com

# Contact form browser key (build-time/public)
